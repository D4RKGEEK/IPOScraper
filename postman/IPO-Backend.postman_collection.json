{
  "info": {
    "name": "IPO Platform API (V2)",
    "description": "Collection covering the Main API and Extraction API (Port 3001)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Main API (Port 3001)",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "url": { "raw": "http://localhost:3001/health", "protocol": "http", "host": ["localhost"], "port": "3001", "path": ["health"] }
          }
        },
        {
          "name": "Sources Status",
          "request": {
            "method": "GET",
            "url": { "raw": "http://localhost:3001/sources", "protocol": "http", "host": ["localhost"], "port": "3001", "path": ["sources"] }
          }
        },
        {
          "name": "List IPOs",
          "request": {
            "method": "GET",
            "url": { "raw": "http://localhost:3001/ipos", "protocol": "http", "host": ["localhost"], "port": "3001", "path": ["ipos"] }
          }
        },
        {
          "name": "Get Single IPO",
          "request": {
            "method": "GET",
            "url": { "raw": "http://localhost:3001/ipos/ola-electric-ipo", "protocol": "http", "host": ["localhost"], "port": "3001", "path": ["ipos", "ola-electric-ipo"] }
          }
