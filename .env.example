# MongoDB
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
UPSTOX_ACCESS_TOKEN=

# MongoDB Connection Configuration
MONGODB_URI="mongodb://localhost:27017"
MONGODB_DB="ipo"

# ── Extraction pipeline ───────────────────────────────────────────────────
# Gemini 2.5 Flash (structured extraction + LLM fallback)
GEMINI_API_KEY=""

# DeepSeek (ToC/locate fallback — cheap, tried first before Gemini)
DEEPSEEK_API_KEY=""

# Firecrawl /v2/parse (per-section extraction alternative to Gemini)
FIRECRAWL_API_KEY=""

# Python executable (override if using a venv, e.g. ./src/extraction/python/.venv/bin/python3)
PYTHON_BIN="python3"

# X-API-Key protecting sensitive endpoints
SERVICE_API_KEY=""

# ── Dashboard login ───────────────────────────────────────────────────────
# Leave DASHBOARD_PASSWORD empty to DISABLE the login gate (open dashboard).
# Set it to require sign-in to the control panel + all API routes.
DASHBOARD_USER="admin"
DASHBOARD_PASSWORD=""
# HMAC signing key for session tokens. Set a long random string in production.
# (If empty, a key is derived from the password so login still works.)
DASHBOARD_SECRET=""
