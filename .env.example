# MongoDB
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
UPSTOX_ACCESS_TOKEN=

# MongoDB Connection Configuration
MONGODB_URI="mongodb://localhost:27017"
MONGODB_DB="ipo"

# ── Extraction pipeline ───────────────────────────────────────────────────
# Gemini 2.5 Flash (structured extraction + LLM fallback)
GEMINI_API_KEY=""

# DeepSeek (ToC/locate fallback — cheap, tried first before Gemini)
DEEPSEEK_API_KEY=""

# OpenAI (GPT-4o-mini, GPT-4o, etc. - for extraction fallback)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Firecrawl /v2/parse (per-section extraction alternative to Gemini)
FIRECRAWL_API_KEY=""

# Python executable (override if using a venv, e.g. ./src/extraction/python/.venv/bin/python3)
PYTHON_BIN="python3"

# ── R2 (Cloudflare) document store — OPTIONAL ─────────────────────────────
# Caches the converted markdown per document so re-extractions skip the
# expensive download + PDF→markdown convert. Leave any blank to disable R2
# entirely (extraction still works, just re-downloads + re-converts each run).
# Only the CURRENT document per IPO is kept; superseded docs are purged.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""

# X-API-Key protecting sensitive endpoints
SERVICE_API_KEY=""

# ── Cascade order (extraction pipeline fallback) ────────────────────────────
# Comma-separated list of engines to try in order: firecrawl, gemini, deepseek, openai
# Example: EXTRACTION_CASCADE="firecrawl,gemini,deepseek,openai"
# (Firecrawl is always first; this controls the fallback order)
EXTRACTION_CASCADE="firecrawl,gemini,deepseek,openai"

# ── Dashboard login ───────────────────────────────────────────────────────
# Leave DASHBOARD_PASSWORD empty to DISABLE the login gate (open dashboard).
# Set it to require sign-in to the control panel + all API routes.
DASHBOARD_USER="admin"
DASHBOARD_PASSWORD=""
# HMAC signing key for session tokens. Set a long random string in production.
# (If empty, a key is derived from the password so login still works.)
DASHBOARD_SECRET=""
