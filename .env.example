# MongoDB
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
UPSTOX_ACCESS_TOKEN=

# MongoDB Connection Configuration
MONGODB_URI="mongodb://localhost:27017"
MONGODB_DB="ipo"

# ── Extraction pipeline (PRD v2.1) ────────────────────────────────────────
# Separate Mongo DB so PRD collection names don't clash with the scraper's.
MONGODB_EXTRACTION_DB="ipo_extraction"

# Cloudflare R2 (blob workbench: pdf/, work/, review/ prefixes only)
R2_ENDPOINT="https://<account>.r2.cloudflarestorage.com"
R2_BUCKET=""
R2_ACCESS_KEY_ID=""
R2_SECRET=""

# Firecrawl /parse (primary extractor) + DeepSeek (fallback brain)
FIRECRAWL_API_KEY=""
DEEPSEEK_API_KEY=""

# DeepSeek costs real money; Firecrawl credits don't. Off by default: the field
# ladder is Firecrawl-only (clean HTML -> mini-PDF -> review). Set to "true" to
# re-enable DeepSeek as a last-resort text fallback. (The rare section locator
# uses DeepSeek regardless — that call is tiny.)
EXTRACT_USE_DEEPSEEK="false"

# X-API-Key protecting the extraction routes (mounted at /v1 on the main API).
# Invent any strong secret, e.g.: openssl rand -hex 32
SERVICE_API_KEY=""
